{
	"name": "eslint-config-reverentgeek",
	"version": "7.0.2",
	"description": "ESLint rules that ReverentGeek likes :)",
	"main": "src/index.js",
	"exports": {
		".": "./src/index.js"
	},
	"files": [
		"src"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/reverentgeek/eslint-config-reverentgeek.git"
	},
	"scripts": {
		"lint": "eslint ./ --fix",
		"lint:check": "eslint ./",
		"test": "node --test --experimental-test-coverage test/*.js",
		"validate": "npm run lint:check && npm run test",
		"prepare": "git config core.hooksPath .githooks"
	},
	"keywords": [
		"lint",
		"eslint",
		"reverentgeek"
	],
	"author": "David Neal <david@reverentgeek.com> (https://reverentgeek.com)",
	"license": "MIT",
	"dependencies": {
		"@eslint/js": "^10.0.1",
		"@stylistic/eslint-plugin": "^5.9.0",
		"eslint-plugin-n": "^17.24.0",
		"globals": "^17.3.0"
	},
	"peerDependencies": {
		"eslint": ">=10.0.0"
	},
	"devDependencies": {
		"eslint": "^10.0.2"
	},
	"engines": {
		"node": ">=18.0.0"
	},
	"packageManager": "pnpm@10.30.2+sha512.36cdc707e7b7940a988c9c1ecf88d084f8514b5c3f085f53a2e244c2921d3b2545bc20dd4ebe1fc245feec463bb298aecea7a63ed1f7680b877dc6379d8d0cb4"
}
