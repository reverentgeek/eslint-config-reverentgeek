{
	"name": "eslint-config-reverentgeek",
	"version": "7.1.9",
	"description": "ESLint rules that ReverentGeek likes :)",
	"main": "src/index.js",
	"exports": {
		".": "./src/index.js"
	},
	"files": [
		"src"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/reverentgeek/eslint-config-reverentgeek.git"
	},
	"scripts": {
		"lint": "eslint ./ --fix",
		"lint:check": "eslint ./",
		"test": "node --test --experimental-test-coverage test/*.js",
		"validate": "npm run lint:check && npm run test",
		"prepare": "git config core.hooksPath .githooks"
	},
	"keywords": [
		"lint",
		"eslint",
		"reverentgeek"
	],
	"author": "David Neal <david@reverentgeek.com> (https://reverentgeek.com)",
	"license": "MIT",
	"dependencies": {
		"@eslint/js": "^10.0.1",
		"@stylistic/eslint-plugin": "^5.10.0",
		"eslint-plugin-n": "^18.1.0",
		"globals": "^17.6.0"
	},
	"peerDependencies": {
		"eslint": ">=10.0.0"
	},
	"devDependencies": {
		"eslint": "^10.4.1"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"packageManager": "pnpm@11.5.3+sha512.7ac1c919341c213a34dc0d02afb7143c5c26ac26ee8c4782deea821b8ac64d2134a081fd8941dae6e29bbb48f58dfc2b7fbceeccc07cb2f09d219d342a4969ed"
}
