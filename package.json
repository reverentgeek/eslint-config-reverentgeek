{
	"name": "eslint-config-reverentgeek",
	"version": "7.1.0",
	"description": "ESLint rules that ReverentGeek likes :)",
	"main": "src/index.js",
	"exports": {
		".": "./src/index.js"
	},
	"files": [
		"src"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/reverentgeek/eslint-config-reverentgeek.git"
	},
	"scripts": {
		"lint": "eslint ./ --fix",
		"lint:check": "eslint ./",
		"test": "node --test --experimental-test-coverage test/*.js",
		"validate": "npm run lint:check && npm run test",
		"prepare": "git config core.hooksPath .githooks"
	},
	"keywords": [
		"lint",
		"eslint",
		"reverentgeek"
	],
	"author": "David Neal <david@reverentgeek.com> (https://reverentgeek.com)",
	"license": "MIT",
	"dependencies": {
		"@eslint/js": "^10.0.1",
		"@stylistic/eslint-plugin": "^5.10.0",
		"eslint-plugin-n": "^17.24.0",
		"globals": "^17.4.0"
	},
	"peerDependencies": {
		"eslint": ">=10.0.0"
	},
	"devDependencies": {
		"eslint": "^10.0.3"
	},
	"engines": {
		"node": ">=18.0.0"
	},
	"packageManager": "pnpm@10.31.0+sha512.e3927388bfaa8078ceb79b748ffc1e8274e84d75163e67bc22e06c0d3aed43dd153151cbf11d7f8301ff4acb98c68bdc5cadf6989532801ffafe3b3e4a63c268"
}