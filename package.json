{
	"name": "eslint-config-reverentgeek",
	"version": "7.1.4",
	"description": "ESLint rules that ReverentGeek likes :)",
	"main": "src/index.js",
	"exports": {
		".": "./src/index.js"
	},
	"files": [
		"src"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/reverentgeek/eslint-config-reverentgeek.git"
	},
	"scripts": {
		"lint": "eslint ./ --fix",
		"lint:check": "eslint ./",
		"test": "node --test --experimental-test-coverage test/*.js",
		"validate": "npm run lint:check && npm run test",
		"prepare": "git config core.hooksPath .githooks"
	},
	"keywords": [
		"lint",
		"eslint",
		"reverentgeek"
	],
	"author": "David Neal <david@reverentgeek.com> (https://reverentgeek.com)",
	"license": "MIT",
	"dependencies": {
		"@eslint/js": "^10.0.1",
		"@stylistic/eslint-plugin": "^5.10.0",
		"eslint-plugin-n": "^17.24.0",
		"globals": "^17.5.0"
	},
	"peerDependencies": {
		"eslint": ">=10.0.0"
	},
	"devDependencies": {
		"eslint": "^10.2.1"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"packageManager": "pnpm@11.0.3+sha512.10448f2988933787c6699aef683174c741f6472ad91b7e3c8fe3e2bda57be8a0f7caf58949b8bc22e624578b3dc6e57876ba4c631928a1b84cc141e12c79bccd"
}
