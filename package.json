{
	"name": "eslint-config-reverentgeek",
	"version": "7.1.11",
	"description": "ESLint rules that ReverentGeek likes :)",
	"main": "src/index.js",
	"exports": {
		".": "./src/index.js"
	},
	"files": [
		"src"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/reverentgeek/eslint-config-reverentgeek.git"
	},
	"scripts": {
		"lint": "eslint ./ --fix",
		"lint:check": "eslint ./",
		"test": "node --test --experimental-test-coverage test/*.js",
		"validate": "npm run lint:check && npm run test",
		"prepare": "git config core.hooksPath .githooks"
	},
	"keywords": [
		"lint",
		"eslint",
		"reverentgeek"
	],
	"author": "David Neal <david@reverentgeek.com> (https://reverentgeek.com)",
	"license": "MIT",
	"dependencies": {
		"@eslint/js": "^10.0.1",
		"@stylistic/eslint-plugin": "^5.10.0",
		"eslint-plugin-n": "^18.1.0",
		"globals": "^17.7.0"
	},
	"peerDependencies": {
		"eslint": ">=10.0.0"
	},
	"devDependencies": {
		"eslint": "^10.5.0"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
